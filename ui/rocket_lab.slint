import { Button, GroupBox, HorizontalBox, Palette, ScrollView, SpinBox, VerticalBox } from "std-widgets.slint";

component MetricCard inherits Rectangle {
    in property <string> title;
    in property <string> value;
    in property <brush> accent: #5b9cff;

    min-width: 176px;
    min-height: 92px;
    border-radius: 18px;
    background: #131d32;
    border-width: 1px;
    border-color: #33435f;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 4px;
        background: root.accent;
        border-top-left-radius: 18px;
        border-top-right-radius: 18px;
    }

    Text {
        x: 16px;
        y: 18px;
        text: root.title;
        color: #aebbd1;
        font-size: 13px;
    }

    Text {
        x: 16px;
        y: 44px;
        text: root.value;
        color: white;
        font-size: 22px;
        font-weight: 600;
    }
}

component SectionTitle inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;

    min-height: 44px;
    background: transparent;

    Text {
        x: 0px;
        y: 2px;
        text: root.title;
        color: white;
        font-size: 18px;
        font-weight: 600;
    }

    Text {
        x: 0px;
        y: 24px;
        text: root.subtitle;
        color: #97a7bf;
        font-size: 12px;
    }
}

component StatusPill inherits Rectangle {
    in property <string> label;
    in property <brush> fill: #163252;
    in property <brush> stroke: #5b9cff;

    min-width: 108px;
    min-height: 30px;
    border-radius: 15px;
    background: root.fill;
    border-width: 1px;
    border-color: root.stroke;

    Text {
        x: 12px;
        y: 7px;
        text: root.label;
        color: white;
        font-size: 12px;
        font-weight: 600;
    }
}

component OverlayNote inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <brush> accent: #5b9cff;

    min-width: 180px;
    min-height: 72px;
    border-radius: 16px;
    background: #121b2f;
    border-width: 1px;
    border-color: #31415c;

    Rectangle {
        x: 0px;
        y: 0px;
        width: 4px;
        height: parent.height;
        background: root.accent;
        border-top-left-radius: 16px;
        border-bottom-left-radius: 16px;
    }

    Text {
        x: 16px;
        y: 12px;
        text: root.title;
        color: white;
        font-size: 14px;
        font-weight: 600;
    }

    Text {
        x: 16px;
        y: 34px;
        width: parent.width - 32px;
        text: root.body;
        color: #98a8c0;
        font-size: 12px;
        wrap: word-wrap;
    }
}

export component RocketLabWindow inherits Window {
    title: "The Rocket Lab";
    width: 1600px;
    height: 960px;
    background: #09111f;

    in-out property <int> workspace_index: 0;
    in-out property <string> active_preset: "Research Starter";
    in-out property <string> nose_shape: "Conical";
    in-out property <string> fin_shape: "Trapezoidal";
    in-out property <string> transition_shape: "Conical";
    in-out property <string> body_material: "Aluminum 6061";
    in-out property <string> nose_material: "PLA-CF";
    in-out property <string> fin_material: "PLA-CF";
    in-out property <string> mission_state: "Ready on stand";
    in-out property <string> mission_hint: "Use the primary control to start the simulation.";
    in-out property <string> weather_source: "Manual";
    in-out property <string> trajectory_summary: "Trajectory summary will appear after launch.";
    in-out property <string> keyframe_status: "Launch keyframe ready";

    in-out property <string> model_mass: "0.00 kg";
    in-out property <string> model_stability: "0.00 cal";
    in-out property <string> model_cgcp: "0.00 / 0.00 m";
    in-out property <string> model_drag: "Cd 0.00";
    in-out property <string> sim_time: "0.00 s";
    in-out property <string> sim_altitude: "0.0 m";
    in-out property <string> sim_speed: "0.0 m/s";
    in-out property <string> sim_mach: "0.00";
    in-out property <string> sim_aoa: "0.00 deg";
    in-out property <string> sim_dynamic_pressure: "0 Pa";
    in-out property <string> sim_apogee: "0.0 m";
    in-out property <string> sim_range: "0.0 m";

    in-out property <bool> paused: true;
    in-out property <bool> replay_active: false;

    in-out property <int> body_length_cm: 250;
    in-out property <int> body_diameter_mm: 104;
    in-out property <int> wall_thickness_tenths_mm: 30;
    in-out property <int> nose_length_cm: 40;
    in-out property <int> payload_length_cm: 22;
    in-out property <int> payload_mass_g: 900;
    in-out property <int> fin_root_cm: 24;
    in-out property <int> fin_tip_cm: 10;
    in-out property <int> fin_span_cm: 12;
    in-out property <int> fin_sweep_cm: 6;
    in-out property <int> fin_count: 4;
    in-out property <int> motor_count: 2;
    in-out property <int> motor_thrust_n: 180;
    in-out property <int> burn_time_tenths_s: 24;
    in-out property <int> propellant_mass_g: 240;
    in-out property <int> mount_radius_mm: 40;
    in-out property <int> launch_elevation_m: 120;
    in-out property <int> wind_speed_tenths_mps: 20;
    in-out property <int> wind_gust_tenths_mps: 0;
    in-out property <int> wind_direction_deg: 0;
    in-out property <int> deploy_altitude_m: 250;
    in-out property <int> chute_area_tenths_m2: 9;

    in-out property <string> motor_1_label: "Motor 1";
    in-out property <string> motor_2_label: "Motor 2";
    in-out property <string> motor_3_label: "Motor 3";
    in-out property <string> motor_4_label: "Motor 4";
    in-out property <string> motor_5_label: "Motor 5";
    in-out property <string> motor_6_label: "Motor 6";
    in-out property <bool> motor_1_enabled: true;
    in-out property <bool> motor_2_enabled: true;
    in-out property <bool> motor_3_enabled: false;
    in-out property <bool> motor_4_enabled: false;
    in-out property <bool> motor_5_enabled: false;
    in-out property <bool> motor_6_enabled: false;
    in-out property <bool> motor_1_failed: false;
    in-out property <bool> motor_2_failed: false;
    in-out property <bool> motor_3_failed: false;
    in-out property <bool> motor_4_failed: false;
    in-out property <bool> motor_5_failed: false;
    in-out property <bool> motor_6_failed: false;

    callback switch_workspace(int);
    callback select_preset(string);
    callback set_nose_shape(string);
    callback set_fin_shape(string);
    callback set_transition_shape(string);
    callback set_material(string, string);
    callback change_int(string, int);
    callback trigger_action(string);
    callback toggle_motor(int);

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: #09111f;

        Rectangle {
            x: -120px;
            y: -80px;
            width: 460px;
            height: 460px;
            border-radius: 230px;
            background: #12315622;
        }

        Rectangle {
            x: parent.width - 420px;
            y: 48px;
            width: 340px;
            height: 340px;
            border-radius: 170px;
            background: root.workspace_index == 0 ? #3f7bff16 : #3ff1d116;
        }

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 88px;
            background: #0d1628ee;

            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: #2c3951;
            }

            Text {
                x: 28px;
                y: 16px;
                text: "The Rocket Lab";
                color: white;
                font-size: 25px;
                font-weight: 700;
            }

            Text {
                x: 28px;
                y: 48px;
                text: root.workspace_index == 0
                    ? "Design stage: modern shell, CAD-like focus, live flight feedback."
                    : "Flight stage: telemetry, mission timing and 3D energy in one control deck.";
                color: #a3b2c9;
                font-size: 12px;
            }

            HorizontalBox {
                x: 438px;
                y: 21px;
                spacing: 12px;

                Button {
                    text: "Modelazione";
                    primary: root.workspace_index == 0;
                    clicked => { root.switch_workspace(0); }
                }

                Button {
                    text: "Simulazione";
                    primary: root.workspace_index == 1;
                    clicked => { root.switch_workspace(1); }
                }
            }

            Rectangle {
                x: parent.width - 372px;
                y: 14px;
                width: 340px;
                height: 58px;
                border-radius: 18px;
                background: #15233a;
                border-width: 1px;
                border-color: root.workspace_index == 0 ? #4569a4 : #2f8f89;

                Text {
                    x: 16px;
                    y: 10px;
                    text: root.workspace_index == 0 ? "Fusion Workspace / Modeling" : "Fusion Workspace / Simulation";
                    color: white;
                    font-size: 15px;
                    font-weight: 600;
                }

                Text {
                    x: 16px;
                    y: 31px;
                    width: parent.width - 32px;
                    text: root.workspace_index == 0
                        ? "Tool rail, design theater and focused inspector move as one scene."
                        : "Mission deck, live telemetry and scenario control stay in the same visual field.";
                    color: #a9b7cc;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }
        }

        Rectangle {
            x: 22px;
            y: 104px;
            width: parent.width - 44px;
            height: parent.height - 126px;
            border-radius: 28px;
            background: #0d1628e8;
            border-width: 1px;
            border-color: #243249;

            if root.workspace_index == 0 : ScrollView {
                x: 20px;
                y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;

                VerticalBox {
                    spacing: 20px;

                    Rectangle {
                        min-height: 438px;
                        border-radius: 24px;
                        background: #0f1a2d;
                        border-width: 1px;
                        border-color: #30415e;

                        HorizontalBox {
                            x: 18px;
                            y: 18px;
                            width: parent.width - 36px;
                            height: parent.height - 36px;
                            spacing: 18px;

                            GroupBox {
                                title: "Tool Rail & Preset";
                                min-width: 246px;
                                VerticalBox {
                                    spacing: 10px;

                                    SectionTitle { title: "Workspace tools"; subtitle: "La UI moderna prende il rigore, il 3D resta il centro della scena."; }

                                    Button { text: "Select Focus"; primary: true; }
                                    Button { text: "Move / Tune"; }
                                    Button { text: "Rotate Review"; }
                                    Button { text: "Scale Balance"; }
                                    Button { text: "Measure Snap"; }

                                    Rectangle { min-height: 1px; background: #25334a; }

                                    Text { text: "Project preset"; color: white; font-weight: 600; }
                                    Button { text: "Research Starter"; primary: root.active_preset == "Research Starter"; clicked => { root.select_preset("Research Starter"); } }
                                    Button { text: "Sport Trainer"; primary: root.active_preset == "Sport Trainer"; clicked => { root.select_preset("Sport Trainer"); } }
                                    Button { text: "High Altitude"; primary: root.active_preset == "High Altitude"; clicked => { root.select_preset("High Altitude"); } }
                                    Button { text: "Minimum Diameter"; primary: root.active_preset == "Minimum Diameter"; clicked => { root.select_preset("Minimum Diameter"); } }
                                    Button { text: "Heavy Lift"; primary: root.active_preset == "Heavy Lift"; clicked => { root.select_preset("Heavy Lift"); } }
                                }
                            }

                            Rectangle {
                                min-width: 640px;
                                min-height: 398px;
                                border-radius: 24px;
                                background: #0a1221;
                                border-width: 1px;
                                border-color: #36527a;

                                Rectangle {
                                    x: 22px;
                                    y: 22px;
                                    width: parent.width - 44px;
                                    height: 64px;
                                    border-radius: 18px;
                                    background: #101b30dd;
                                    border-width: 1px;
                                    border-color: #2e425f;

                                    Text {
                                        x: 18px;
                                        y: 11px;
                                        text: "Design Theater";
                                        color: white;
                                        font-size: 20px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        x: 18px;
                                        y: 36px;
                                        width: parent.width - 36px;
                                        text: "La viewport deve sembrare il punto d’origine di tutto: geometria, overlay, materiali e stabilita.";
                                        color: #9fb0c8;
                                        font-size: 12px;
                                    }
                                }

                                Rectangle {
                                    x: 34px;
                                    y: 110px;
                                    width: parent.width - 68px;
                                    height: 190px;
                                    border-radius: 22px;
                                    background: #0e1830;
                                    border-width: 1px;
                                    border-color: #34517d;
                                }

                                Rectangle {
                                    x: 94px;
                                    y: 124px;
                                    width: parent.width - 188px;
                                    height: 162px;
                                    border-radius: 81px;
                                    background: #4583ff14;
                                }

                                Rectangle {
                                    x: 130px;
                                    y: 132px;
                                    width: parent.width - 260px;
                                    height: 146px;
                                    border-radius: 73px;
                                    background: #7fb6ff12;
                                }

                                Text {
                                    x: 58px;
                                    y: 142px;
                                    text: root.nose_shape;
                                    color: white;
                                    font-size: 14px;
                                    font-weight: 600;
                                }

                                Text {
                                    x: parent.width - 186px;
                                    y: 142px;
                                    text: root.fin_shape;
                                    color: white;
                                    font-size: 14px;
                                    font-weight: 600;
                                }

                                Text {
                                    x: parent.width / 2 - 98px;
                                    y: 167px;
                                    text: "Rocket core";
                                    color: #dfe8f5;
                                    font-size: 26px;
                                    font-weight: 700;
                                }

                                Text {
                                    x: parent.width / 2 - 178px;
                                    y: 202px;
                                    width: 356px;
                                    text: "Clean modern shell outside, 3D-oriented reading inside. Nessun pannello deve sembrare staccato dal corpo del razzo.";
                                    color: #a4b3c9;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                }

                                HorizontalBox {
                                    x: 34px;
                                    y: 320px;
                                    spacing: 12px;

                                    StatusPill { label: "Preset " + root.active_preset; fill: #193255; stroke: #5b9cff; }
                                    StatusPill { label: "Body " + root.body_material; fill: #183527; stroke: #47d59e; }
                                    StatusPill { label: "Transition " + root.transition_shape; fill: #3d2c13; stroke: #f0a74b; }
                                }

                                HorizontalBox {
                                    x: 34px;
                                    y: 366px;
                                    spacing: 12px;

                                    OverlayNote { title: "Primary axis"; body: "CG/CP e drag devono essere leggibili come overlay, non come tabella isolata."; accent: #5b9cff; }
                                    OverlayNote { title: "Viewport rhythm"; body: "Inspector e outliner supportano la scena, ma la scena resta il protagonista."; accent: #47d59e; }
                                    OverlayNote { title: "Precision layer"; body: "Le quote numeriche restano vicine al centro per dare continuita al gesto di modifica."; accent: #f0a74b; }
                                }
                            }

                            GroupBox {
                                title: "Focused Inspector";
                                min-width: 338px;
                                VerticalBox {
                                    spacing: 12px;

                                    SectionTitle { title: "Component snapshot"; subtitle: "La precisione del nuovo incontra il comportamento da viewport tecnica."; }

                                    Text { text: "Active preset: " + root.active_preset; }
                                    Text { text: "Nose profile: " + root.nose_shape; }
                                    Text { text: "Fin profile: " + root.fin_shape; }
                                    Text { text: "Transition: " + root.transition_shape; }
                                    Text { text: "Mass / stability: " + root.model_mass + " / " + root.model_stability; }
                                    Text { text: "CG / CP: " + root.model_cgcp; }

                                    Rectangle { min-height: 1px; background: #25334a; }

                                    Text { text: "Nose cone"; color: white; font-weight: 600; }
                                    HorizontalBox {
                                        spacing: 8px;
                                        Button { text: "Conical"; primary: root.nose_shape == "Conical"; clicked => { root.set_nose_shape("Conical"); } }
                                        Button { text: "Tangent Ogive"; primary: root.nose_shape == "Tangent Ogive"; clicked => { root.set_nose_shape("Tangent Ogive"); } }
                                    }
                                    HorizontalBox {
                                        spacing: 8px;
                                        Button { text: "Parabolic"; primary: root.nose_shape == "Parabolic"; clicked => { root.set_nose_shape("Parabolic"); } }
                                        Button { text: "LD-Haack"; primary: root.nose_shape == "LD-Haack"; clicked => { root.set_nose_shape("LD-Haack"); } }
                                    }

                                    Text { text: "Fin set"; color: white; font-weight: 600; }
                                    HorizontalBox {
                                        spacing: 8px;
                                        Button { text: "Trapezoidal"; primary: root.fin_shape == "Trapezoidal"; clicked => { root.set_fin_shape("Trapezoidal"); } }
                                        Button { text: "Elliptical"; primary: root.fin_shape == "Elliptical"; clicked => { root.set_fin_shape("Elliptical"); } }
                                        Button { text: "Airfoil"; primary: root.fin_shape == "Airfoil"; clicked => { root.set_fin_shape("Airfoil"); } }
                                    }

                                    Text { text: root.mission_hint; color: #a9b7cc; wrap: word-wrap; }
                                }
                            }
                        }
                    }

                    HorizontalBox {
                        spacing: 16px;

                        MetricCard { title: "Massa stimata"; value: root.model_mass; accent: #5b9cff; }
                        MetricCard { title: "Stabilita"; value: root.model_stability; accent: #47d59e; }
                        MetricCard { title: "CG / CP"; value: root.model_cgcp; accent: #f0a74b; }
                        MetricCard { title: "Drag"; value: root.model_drag; accent: #cf84ff; }
                    }

                    HorizontalBox {
                        spacing: 18px;

                        GroupBox {
                            title: "Geometria primaria";
                            min-width: 560px;
                            VerticalBox {
                                spacing: 12px;

                                SectionTitle { title: "Hull and payload"; subtitle: "Le quote restano ordinate ma vivono nello stesso workspace della scena."; }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Body length (cm)"; vertical-alignment: center; min-width: 160px; }
                                    SpinBox { value: root.body_length_cm; minimum: 80; maximum: 800; edited(value) => { root.change_int("body_length_cm", value); } }
                                    Text { text: "Body diameter (mm)"; vertical-alignment: center; min-width: 170px; }
                                    SpinBox { value: root.body_diameter_mm; minimum: 40; maximum: 350; edited(value) => { root.change_int("body_diameter_mm", value); } }
                                }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Wall thickness (0.1 mm)"; vertical-alignment: center; min-width: 160px; }
                                    SpinBox { value: root.wall_thickness_tenths_mm; minimum: 15; maximum: 100; edited(value) => { root.change_int("wall_thickness_tenths_mm", value); } }
                                    Text { text: "Nose length (cm)"; vertical-alignment: center; min-width: 170px; }
                                    SpinBox { value: root.nose_length_cm; minimum: 12; maximum: 250; edited(value) => { root.change_int("nose_length_cm", value); } }
                                }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Payload length (cm)"; vertical-alignment: center; min-width: 160px; }
                                    SpinBox { value: root.payload_length_cm; minimum: 8; maximum: 200; edited(value) => { root.change_int("payload_length_cm", value); } }
                                    Text { text: "Payload mass (g)"; vertical-alignment: center; min-width: 170px; }
                                    SpinBox { value: root.payload_mass_g; minimum: 100; maximum: 8000; step-size: 50; edited(value) => { root.change_int("payload_mass_g", value); } }
                                }
                            }
                        }

                        GroupBox {
                            title: "Fin set & cluster";
                            min-width: 520px;
                            VerticalBox {
                                spacing: 12px;

                                SectionTitle { title: "Stability and thrust"; subtitle: "Controlli ravvicinati come in un CAD leggero, lettura diretta come in una viewport tecnica."; }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Fin root (cm)"; min-width: 140px; vertical-alignment: center; }
                                    SpinBox { value: root.fin_root_cm; minimum: 8; maximum: 150; edited(value) => { root.change_int("fin_root_cm", value); } }
                                    Text { text: "Fin tip (cm)"; min-width: 120px; vertical-alignment: center; }
                                    SpinBox { value: root.fin_tip_cm; minimum: 4; maximum: 120; edited(value) => { root.change_int("fin_tip_cm", value); } }
                                }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Fin span (cm)"; min-width: 140px; vertical-alignment: center; }
                                    SpinBox { value: root.fin_span_cm; minimum: 4; maximum: 80; edited(value) => { root.change_int("fin_span_cm", value); } }
                                    Text { text: "Fin sweep (cm)"; min-width: 120px; vertical-alignment: center; }
                                    SpinBox { value: root.fin_sweep_cm; minimum: 0; maximum: 80; edited(value) => { root.change_int("fin_sweep_cm", value); } }
                                }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Fin count"; min-width: 140px; vertical-alignment: center; }
                                    SpinBox { value: root.fin_count; minimum: 3; maximum: 6; edited(value) => { root.change_int("fin_count", value); } }
                                    Text { text: "Motor count"; min-width: 120px; vertical-alignment: center; }
                                    SpinBox { value: root.motor_count; minimum: 1; maximum: 6; edited(value) => { root.change_int("motor_count", value); } }
                                }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Thrust each (N)"; min-width: 140px; vertical-alignment: center; }
                                    SpinBox { value: root.motor_thrust_n; minimum: 20; maximum: 2500; step-size: 10; edited(value) => { root.change_int("motor_thrust_n", value); } }
                                    Text { text: "Burn time (0.1 s)"; min-width: 120px; vertical-alignment: center; }
                                    SpinBox { value: root.burn_time_tenths_s; minimum: 4; maximum: 200; edited(value) => { root.change_int("burn_time_tenths_s", value); } }
                                }

                                HorizontalBox {
                                    spacing: 16px;
                                    Text { text: "Prop mass (g)"; min-width: 140px; vertical-alignment: center; }
                                    SpinBox { value: root.propellant_mass_g; minimum: 20; maximum: 8000; step-size: 20; edited(value) => { root.change_int("propellant_mass_g", value); } }
                                    Text { text: "Mount radius (mm)"; min-width: 120px; vertical-alignment: center; }
                                    SpinBox { value: root.mount_radius_mm; minimum: 0; maximum: 120; edited(value) => { root.change_int("mount_radius_mm", value); } }
                                }
                            }
                        }

                        GroupBox {
                            title: "Materials & Readiness";
                            min-width: 360px;
                            VerticalBox {
                                spacing: 12px;

                                SectionTitle { title: "Visual material stack"; subtitle: "Il linguaggio moderno resta pulito, ma agganciato al comportamento del razzo."; }

                                Text { text: "Body"; font-weight: 600; }
                                HorizontalBox {
                                    spacing: 8px;
                                    Button { text: "PLA-CF"; primary: root.body_material == "PLA-CF"; clicked => { root.set_material("body", "PLA-CF"); } }
                                    Button { text: "Aluminum 6061"; primary: root.body_material == "Aluminum 6061"; clicked => { root.set_material("body", "Aluminum 6061"); } }
                                    Button { text: "PVC"; primary: root.body_material == "PVC"; clicked => { root.set_material("body", "PVC"); } }
                                }

                                Text { text: "Nose"; font-weight: 600; }
                                HorizontalBox {
                                    spacing: 8px;
                                    Button { text: "PLA-CF"; primary: root.nose_material == "PLA-CF"; clicked => { root.set_material("nose", "PLA-CF"); } }
                                    Button { text: "Aluminum 6061"; primary: root.nose_material == "Aluminum 6061"; clicked => { root.set_material("nose", "Aluminum 6061"); } }
                                    Button { text: "PVC"; primary: root.nose_material == "PVC"; clicked => { root.set_material("nose", "PVC"); } }
                                }

                                Text { text: "Fins"; font-weight: 600; }
                                HorizontalBox {
                                    spacing: 8px;
                                    Button { text: "PLA-CF"; primary: root.fin_material == "PLA-CF"; clicked => { root.set_material("fins", "PLA-CF"); } }
                                    Button { text: "Aluminum 6061"; primary: root.fin_material == "Aluminum 6061"; clicked => { root.set_material("fins", "Aluminum 6061"); } }
                                    Button { text: "PVC"; primary: root.fin_material == "PVC"; clicked => { root.set_material("fins", "PVC"); } }
                                }

                                Text { text: "Transition"; font-weight: 600; }
                                HorizontalBox {
                                    spacing: 8px;
                                    Button { text: "Conical"; primary: root.transition_shape == "Conical"; clicked => { root.set_transition_shape("Conical"); } }
                                    Button { text: "Curved"; primary: root.transition_shape == "Curved"; clicked => { root.set_transition_shape("Curved"); } }
                                }

                                Rectangle { min-height: 1px; background: #25334a; }

                                Text { text: "Snapshot"; font-weight: 600; }
                                Text { text: "Preset attivo: " + root.active_preset; }
                                Text { text: "Ogiva: " + root.nose_shape; }
                                Text { text: "Pinne: " + root.fin_shape; }
                                Text { text: root.mission_hint; color: #a9b7cc; wrap: word-wrap; }
                            }
                        }
                    }
                }
            }

            if root.workspace_index == 1 : ScrollView {
                x: 20px;
                y: 20px;
                width: parent.width - 40px;
                height: parent.height - 40px;

                VerticalBox {
                    spacing: 20px;

                    HorizontalBox {
                        spacing: 16px;

                        MetricCard { title: "Tempo"; value: root.sim_time; accent: #5b9cff; }
                        MetricCard { title: "Quota"; value: root.sim_altitude; accent: #7fb6ff; }
                        MetricCard { title: "Velocita aria"; value: root.sim_speed; accent: #47d59e; }
                        MetricCard { title: "Mach"; value: root.sim_mach; accent: #cf84ff; }
                        MetricCard { title: "AoA"; value: root.sim_aoa; accent: #f0a74b; }
                        MetricCard { title: "Apogeo"; value: root.sim_apogee; accent: #ff8cab; }
                    }

                    Rectangle {
                        min-height: 454px;
                        border-radius: 24px;
                        background: #0f182b;
                        border-width: 1px;
                        border-color: #2e415d;

                        HorizontalBox {
                            x: 18px;
                            y: 18px;
                            width: parent.width - 36px;
                            height: parent.height - 36px;
                            spacing: 18px;

                            GroupBox {
                                title: "Mission Control";
                                min-width: 312px;
                                VerticalBox {
                                    spacing: 12px;

                                    SectionTitle { title: root.mission_state; subtitle: root.mission_hint; }

                                    Button {
                                        text: root.paused ? "Avvia / Riprendi" : "Pausa";
                                        primary: true;
                                        clicked => { root.trigger_action("toggle_pause"); }
                                    }

                                    Button {
                                        text: "Reset missione";
                                        clicked => { root.trigger_action("reset"); }
                                    }

                                    Button {
                                        text: root.replay_active ? "Ferma replay" : "Avvia replay";
                                        primary: root.replay_active;
                                        clicked => { root.trigger_action("toggle_replay"); }
                                    }

                                    Button {
                                        text: "Keyframe successivo";
                                        clicked => { root.trigger_action("next_keyframe"); }
                                    }

                                    Rectangle { min-height: 1px; background: #25334a; }

                                    Text { text: "Keyframe: " + root.keyframe_status; color: #c1ccdd; wrap: word-wrap; }
                                    Text { text: "Range: " + root.sim_range; color: #a9b7cc; }
                                    Text { text: "Pressione dinamica: " + root.sim_dynamic_pressure; color: #a9b7cc; }
                                    Text { text: "Weather source: " + root.weather_source; color: #a9b7cc; }
                                }
                            }

                            Rectangle {
                                min-width: 650px;
                                min-height: 414px;
                                border-radius: 24px;
                                background: #09111f;
                                border-width: 1px;
                                border-color: #2d6e76;

                                Rectangle {
                                    x: 20px;
                                    y: 20px;
                                    width: parent.width - 40px;
                                    height: 68px;
                                    border-radius: 18px;
                                    background: #101b30dd;
                                    border-width: 1px;
                                    border-color: #294d57;

                                    Text {
                                        x: 18px;
                                        y: 10px;
                                        text: "Flight Deck";
                                        color: white;
                                        font-size: 20px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        x: 18px;
                                        y: 36px;
                                        width: parent.width - 36px;
                                        text: "La control room e il volo devono sembrare la stessa superficie: energia visiva del 3D, chiarezza della nuova UI.";
                                        color: #a3b2c9;
                                        font-size: 12px;
                                    }
                                }

                                Rectangle {
                                    x: 34px;
                                    y: 112px;
                                    width: parent.width - 68px;
                                    height: 170px;
                                    border-radius: 22px;
                                    background: #0e1830;
                                    border-width: 1px;
                                    border-color: #245c68;
                                }

                                Rectangle {
                                    x: 90px;
                                    y: 126px;
                                    width: parent.width - 180px;
                                    height: 142px;
                                    border-radius: 71px;
                                    background: root.replay_active ? #ffb13b18 : #44ebd116;
                                }

                                Text {
                                    x: parent.width / 2 - 92px;
                                    y: 148px;
                                    text: root.mission_state;
                                    color: white;
                                    font-size: 24px;
                                    font-weight: 700;
                                }

                                Text {
                                    x: parent.width / 2 - 184px;
                                    y: 182px;
                                    width: 368px;
                                    text: root.trajectory_summary;
                                    color: #a7b6cb;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                }

                                HorizontalBox {
                                    x: 34px;
                                    y: 300px;
                                    spacing: 12px;

                                    StatusPill { label: "Time " + root.sim_time; fill: #163252; stroke: #5b9cff; }
                                    StatusPill { label: "Mach " + root.sim_mach; fill: #31224f; stroke: #cf84ff; }
                                    StatusPill { label: "AoA " + root.sim_aoa; fill: #442d14; stroke: #f0a74b; }
                                    StatusPill { label: "Replay " + (root.replay_active ? "ON" : "OFF"); fill: root.replay_active ? #3b2a12 : #1c283a; stroke: root.replay_active ? #f0a74b : #4e607b; }
                                }

                                HorizontalBox {
                                    x: 34px;
                                    y: 346px;
                                    spacing: 12px;

                                    OverlayNote { title: "Trajectory layer"; body: "Tempo, keyframe e traiettoria non sono moduli esterni: leggono la stessa scena di volo."; accent: #5b9cff; }
                                    OverlayNote { title: "Event rhythm"; body: "Burnout, apogeo e replay diventano parte della composizione centrale."; accent: #47d59e; }
                                    OverlayNote { title: "Dynamic focus"; body: "Missione e scenario restano vicini alla superficie principale per non spezzare il flusso."; accent: #ff8cab; }
                                }
                            }

                            GroupBox {
                                title: "Scenario Ambiente";
                                min-width: 352px;
                                VerticalBox {
                                    spacing: 12px;

                                    SectionTitle { title: "Site, wind, recovery"; subtitle: "Scenario e lettura di missione nello stesso campo visivo."; }

                                    HorizontalBox {
                                        spacing: 16px;
                                        Text { text: "Launch elevation (m)"; min-width: 160px; vertical-alignment: center; }
                                        SpinBox { value: root.launch_elevation_m; minimum: -50; maximum: 3500; step-size: 5; edited(value) => { root.change_int("launch_elevation_m", value); } }
                                    }

                                    HorizontalBox {
                                        spacing: 16px;
                                        Text { text: "Wind avg (0.1 m/s)"; min-width: 160px; vertical-alignment: center; }
                                        SpinBox { value: root.wind_speed_tenths_mps; minimum: 0; maximum: 350; edited(value) => { root.change_int("wind_speed_tenths_mps", value); } }
                                    }

                                    HorizontalBox {
                                        spacing: 16px;
                                        Text { text: "Wind gust (0.1 m/s)"; min-width: 160px; vertical-alignment: center; }
                                        SpinBox { value: root.wind_gust_tenths_mps; minimum: 0; maximum: 450; edited(value) => { root.change_int("wind_gust_tenths_mps", value); } }
                                    }

                                    HorizontalBox {
                                        spacing: 16px;
                                        Text { text: "Wind dir (deg)"; min-width: 160px; vertical-alignment: center; }
                                        SpinBox { value: root.wind_direction_deg; minimum: 0; maximum: 359; edited(value) => { root.change_int("wind_direction_deg", value); } }
                                    }

                                    HorizontalBox {
                                        spacing: 16px;
                                        Text { text: "Deploy altitude (m)"; min-width: 160px; vertical-alignment: center; }
                                        SpinBox { value: root.deploy_altitude_m; minimum: 30; maximum: 1200; step-size: 10; edited(value) => { root.change_int("deploy_altitude_m", value); } }
                                    }

                                    HorizontalBox {
                                        spacing: 16px;
                                        Text { text: "Chute area (0.1 m2)"; min-width: 160px; vertical-alignment: center; }
                                        SpinBox { value: root.chute_area_tenths_m2; minimum: 1; maximum: 80; edited(value) => { root.change_int("chute_area_tenths_m2", value); } }
                                    }
                                }
                            }
                        }
                    }

                    HorizontalBox {
                        spacing: 18px;

                        GroupBox {
                            title: "Motor Cluster";
                            min-width: 450px;
                            VerticalBox {
                                spacing: 12px;

                                SectionTitle { title: "Failure toggles"; subtitle: "Test di missione a portata di mano, senza staccarsi dal flight deck."; }

                                HorizontalBox {
                                    spacing: 8px;
                                    Button { text: root.motor_1_label; enabled: root.motor_1_enabled; primary: !root.motor_1_failed; clicked => { root.toggle_motor(0); } }
                                    Button { text: root.motor_2_label; enabled: root.motor_2_enabled; primary: !root.motor_2_failed; clicked => { root.toggle_motor(1); } }
                                }
                                HorizontalBox {
                                    spacing: 8px;
                                    Button { text: root.motor_3_label; enabled: root.motor_3_enabled; primary: !root.motor_3_failed; clicked => { root.toggle_motor(2); } }
                                    Button { text: root.motor_4_label; enabled: root.motor_4_enabled; primary: !root.motor_4_failed; clicked => { root.toggle_motor(3); } }
                                }
                                HorizontalBox {
                                    spacing: 8px;
                                    Button { text: root.motor_5_label; enabled: root.motor_5_enabled; primary: !root.motor_5_failed; clicked => { root.toggle_motor(4); } }
                                    Button { text: root.motor_6_label; enabled: root.motor_6_enabled; primary: !root.motor_6_failed; clicked => { root.toggle_motor(5); } }
                                }

                                Text { text: "Ogni motore puo passare tra OK e FAILED mantenendo leggibile il rapporto tra test e traiettoria."; color: #a9b7cc; wrap: word-wrap; }
                            }
                        }

                        GroupBox {
                            title: "Flight Analysis";
                            min-width: 826px;
                            VerticalBox {
                                spacing: 12px;

                                SectionTitle { title: "Mission overview"; subtitle: "La lettura analitica si appoggia alla stessa superficie visiva del volo."; }

                                Rectangle {
                                    min-height: 180px;
                                    border-radius: 18px;
                                    background: #131f34;
                                    border-width: 1px;
                                    border-color: #334760;

                                    Text {
                                        x: 18px;
                                        y: 18px;
                                        width: parent.width - 36px;
                                        text: root.trajectory_summary;
                                        color: white;
                                        wrap: word-wrap;
                                        font-size: 14px;
                                    }
                                }

                                HorizontalBox {
                                    spacing: 16px;

                                    MetricCard { title: "Range"; value: root.sim_range; accent: #7fb6ff; }
                                    MetricCard { title: "Q dyn"; value: root.sim_dynamic_pressure; accent: #47d59e; }
                                    MetricCard { title: "Keyframe"; value: root.keyframe_status; accent: #ff8cab; }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
